{
  "name": "portable-doc-mvp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Portable-document MVP — one document, many surfaces.",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "snapshots:ci": "vitest run --passWithNoTests --reporter=default",
    "visual-goldens": "tsx scripts/visual-goldens.ts",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@portable-doc/backend-email": "workspace:*",
    "@portable-doc/backend-ink": "workspace:*",
    "@portable-doc/backend-web-server": "workspace:*",
    "@portable-doc/fixtures": "workspace:*",
    "@portable-doc/primitives": "workspace:*",
    "@types/node": "^25.6.2",
    "prettier": "^3.8.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
