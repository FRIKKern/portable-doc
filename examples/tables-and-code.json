    {
      "id": "tc-h2-code",
      "type": "heading",
      "level": 2,
      "text": "Three code blocks, three languages"
    },
    {
      "id": "tc-code-ts",
      "type": "code",
      "lang": "typescript",
      "value": "export function add(a: number, b: number): number {\n  return a + b;\n}\n\nconst sum = add(2, 3);\nconsole.log(sum);"
    },
    {
      "id": "tc-between-1",
      "type": "paragraph",
      "content": [
        { "type": "text", "value": "Same prose, different syntax — the renderer's job is to keep them visually distinct." }
      ]
    },
    {
      "id": "tc-code-xml",
      "type": "code",
      "lang": "xml",
      "value": "<root>\n  <service name=\"api-gateway\">\n    <region>eu-north-1</region>\n    <status>healthy</status>\n  </service>\n</root>"
    },
    {
      "id": "tc-between-2",
      "type": "paragraph",
      "content": [
        { "type": "text", "value": "XML stresses the renderer's angle-bracket escaping path." }
      ]
    },
    {
      "id": "tc-code-bash",
      "type": "code",
      "lang": "bash",
      "value": "#!/usr/bin/env bash\nset -euo pipefail\n\nfor svc in api-gateway billing search; do\n  curl -sf \"https://status.example.com/$svc\" || echo \"$svc DOWN\"\ndone"
    },
    {
      "id": "tc-outro",
