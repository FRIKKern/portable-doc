              ]
            },
            {
              "id": "nc-d2-paragraph",
              "type": "paragraph",
              "content": [
                { "type": "text", "value": "A paragraph alongside the depth-2 callout." }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nc-depth3-section",
      "type": "section",
      "title": "Depth 3: section -> section -> section -> callout",
