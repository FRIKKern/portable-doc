          "type": "callout",
          "tone": "info",
          "title": "Outer callout (depth 1)",
          "variant": { "tone": "info", "emphasis": "subtle" },
          "content": [
            { "type": "text", "value": "This callout sits one level deep, inside a section." }
          ]
        },
        {
          "id": "nc-d1-paragraph",
          "type": "paragraph",
          "content": [
            { "type": "text", "value": "Paragraph between callouts, still at depth 1." }
          ]
        }
      ]
    },
    {
