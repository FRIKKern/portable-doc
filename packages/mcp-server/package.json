{
  "name": "@portable-doc/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "portable-doc-mcp": "./bin/portable-doc-mcp.mjs"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@portable-doc/backend-email": "workspace:*",
    "@portable-doc/backend-ink": "workspace:*",
    "@portable-doc/backend-web": "workspace:*",
    "@portable-doc/core": "workspace:*",
    "@portable-doc/primitives": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
