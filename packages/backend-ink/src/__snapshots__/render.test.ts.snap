// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderInk — snapshots > incident fixture at width 60 wraps narrower 1`] = `
"Database failover detected

╭─ ✗ Active incident
│ Primary DB became unreachable at 14:32 UTC. Failover 
│ succeeded at 14:33.
╰─

The primary database stopped responding to health checks at 
14:32 UTC. The replica was promoted automatically and the 
API resumed serving traffic at 14:33 UTC. Investigate root 
cause before failing back.

1. Confirm the replica is healthy and accepting writes.
2. Page the on-call DBA to inspect the former primary.
3. Postpone non-critical migrations until failback is complete.

$ kubectl rollout status deploy/api
$ pgcli -h db-replica.svc -c "SELECT 1"
$ tail -f /var/log/incident.log
$ curl -s https://status.example.com/health

[ View incident dashboard ](https://status.example.com/incidents/2026-05-08)

[image: DB CPU graph showing failover spike]

Metric      │ Threshold │ Actual
────────────┼───────────┼───────
Primary CPU │ 80%       │ 99%   
Replica lag │ 5s        │ 0.4s  "
`;

