exports[`renderInk — snapshots > welcome fixture, default options (mono for stable snapshots) 1`] = `
"Welcome to Atlas

Your workspace is ready. Atlas keeps documents, decisions, and people in one 
place — across web, native, email, terminal, and plain text.

╭─ ✓ Setup complete
│ Setup complete. You can now invite your team.
╰─

• Invite your team
• Create your first project
• Customize your workspace

[ Open workspace ](https://example.com/workspace)

────────────────────────────────────────────────────────────────────────────────

────────────────────────────────────────────────────────────────────────────────
What's next
Browse the documentation to learn how Atlas adapts the same document to every 
surface — without losing fidelity.
[ Read the docs ](https://example.com/docs)
────────────────────────────────────────────────────────────────────────────────"
`;
