// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderHtml — snapshots > incident fixture, default options 1`] = `"<!doctype html><html><head><meta charset="utf-8"></head><body style="background:#f9fafb;margin:0;padding:0;"><div style="max-width:600px;margin:0 auto;padding:24px;font-family:-apple-system,'SF Pro Text',system-ui,sans-serif;color:#111827;background:#ffffff"><span style="font-weight:bold">Database failover detected</span><div style="border-left:4px solid #b91c1c;background:#fef2f2;padding:16px;color:#b91c1c"><strong>Active incident</strong> <span>Primary DB became unreachable at 14:32 UTC. Failover succeeded at 14:33.</span></div><span>The primary database stopped responding to health checks at 14:32 UTC. The replica was promoted automatically and the API resumed serving traffic at 14:33 UTC. Investigate root cause before failing back.</span><div style="display:flex;flex-direction:column"><div style="display:flex;flex-direction:row"><span>1. </span><span>Confirm the replica is healthy and accepting writes.</span></div><div style="display:flex;flex-direction:row"><span>2. </span><span>Page the on-call DBA to inspect the former primary.</span></div><div style="display:flex;flex-direction:row"><span>3. </span><span>Postpone non-critical migrations until failback is complete.</span></div></div><div style="display:flex;flex-direction:column"><span><code style="background:#f3f4f6;padding:2px 6px;font-family:ui-monospace,Menlo,monospace;font-size:0.95em">$ kubectl rollout status deploy/api</code></span><span><code style="background:#f3f4f6;padding:2px 6px;font-family:ui-monospace,Menlo,monospace;font-size:0.95em">$ pgcli -h db-replica.svc -c &quot;SELECT 1&quot;</code></span><span><code style="background:#f3f4f6;padding:2px 6px;font-family:ui-monospace,Menlo,monospace;font-size:0.95em">$ tail -f /var/log/incident.log</code></span><span><code style="background:#f3f4f6;padding:2px 6px;font-family:ui-monospace,Menlo,monospace;font-size:0.95em">$ curl -s https://status.example.com/health</code></span></div><a href="https://status.example.com/incidents/2026-05-08" style="display:inline-block;padding:10px 20px;border:2px solid #4f46e5;color:#4f46e5;text-decoration:none;font-weight:bold;border-radius:0">View incident dashboard</a><img src="https://example.com/img/db-cpu.png" alt="DB CPU graph showing failover spike" style="max-width:100%;height:auto"><table role="presentation" style="border-collapse:collapse;width:100%"><tr><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>Metric</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>Threshold</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>Actual</span></td></tr><tr><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>Primary CPU</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>80%</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>99%</span></td></tr><tr><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>Replica lag</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>5s</span></td><td style="border:1px solid #e5e7eb;padding:8px 12px;vertical-align:top"><span>0.4s</span></td></tr></table></div></body></html>"`;

exports[`renderHtml — snapshots > welcome fixture without doctype 1`] = `"<div style="max-width:600px;margin:0 auto;padding:24px;font-family:-apple-system,'SF Pro Text',system-ui,sans-serif;color:#111827;background:#ffffff"><span style="font-weight:bold">Welcome to Atlas</span><span>Your workspace is ready. Atlas keeps documents, decisions, and people in one place — across web, native, email, terminal, and plain text.</span><div style="border-left:4px solid #047857;background:#ecfdf5;padding:16px;color:#047857"><strong>Setup complete</strong> <span>Setup complete. You can now invite your team.</span></div><div style="display:flex;flex-direction:column"><div style="display:flex;flex-direction:row"><span>• </span><span>Invite your team</span></div><div style="display:flex;flex-direction:row"><span>• </span><span>Create your first project</span></div><div style="display:flex;flex-direction:row"><span>• </span><span>Customize your workspace</span></div></div><a href="https://example.com/workspace" style="display:inline-block;padding:10px 20px;background:#4f46e5;color:#ffffff;text-decoration:none;font-weight:bold;border-radius:0">Open workspace</a><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"><div style="display:flex;flex-direction:column"><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"><span style="font-weight:bold">What&#39;s next</span><span>Browse the documentation to learn how Atlas adapts the same document to every surface — without losing fidelity.</span><a href="https://example.com/docs" style="display:inline-block;padding:10px 20px;border:2px solid #4f46e5;color:#4f46e5;text-decoration:none;font-weight:bold;border-radius:0">Read the docs</a><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"></div></div>"`;

exports[`renderHtml — snapshots > welcome fixture, default options 1`] = `"<!doctype html><html><head><meta charset="utf-8"></head><body style="background:#f9fafb;margin:0;padding:0;"><div style="max-width:600px;margin:0 auto;padding:24px;font-family:-apple-system,'SF Pro Text',system-ui,sans-serif;color:#111827;background:#ffffff"><span style="font-weight:bold">Welcome to Atlas</span><span>Your workspace is ready. Atlas keeps documents, decisions, and people in one place — across web, native, email, terminal, and plain text.</span><div style="border-left:4px solid #047857;background:#ecfdf5;padding:16px;color:#047857"><strong>Setup complete</strong> <span>Setup complete. You can now invite your team.</span></div><div style="display:flex;flex-direction:column"><div style="display:flex;flex-direction:row"><span>• </span><span>Invite your team</span></div><div style="display:flex;flex-direction:row"><span>• </span><span>Create your first project</span></div><div style="display:flex;flex-direction:row"><span>• </span><span>Customize your workspace</span></div></div><a href="https://example.com/workspace" style="display:inline-block;padding:10px 20px;background:#4f46e5;color:#ffffff;text-decoration:none;font-weight:bold;border-radius:0">Open workspace</a><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"><div style="display:flex;flex-direction:column"><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"><span style="font-weight:bold">What&#39;s next</span><span>Browse the documentation to learn how Atlas adapts the same document to every surface — without losing fidelity.</span><a href="https://example.com/docs" style="display:inline-block;padding:10px 20px;border:2px solid #4f46e5;color:#4f46e5;text-decoration:none;font-weight:bold;border-radius:0">Read the docs</a><hr style="border:none;border-top:1px solid #e5e7eb;margin:16px 0"></div></div></body></html>"`;
